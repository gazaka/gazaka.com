---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const projects = (await getCollection('projects', ({ data }) => !data.hidden)).sort(
  (a, b) => a.data.order - b.data.order
);

const renderedProjects = await Promise.all(
  projects.map(async (p) => ({ ...p, Content: (await render(p)).Content }))
);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });
---

<Base>
  <Nav home />

  <main>
    <h1>Gareth Southern</h1>
    <p class="muted">Gaz, aka Gazaka. That's the whole joke.</p>

    <p>
      I work in IT service delivery. At home I run a small pile of self-hosted
      services on this domain and spend a lot of my spare time building,
      breaking and fixing them. This site is the front door: the things I've
      made, and some notes along the way.
    </p>

    <h2 id="about">About</h2>
    <p>
      I spent fourteen years in banking before switching to IT. Self-taught,
      then made official with an NVQ Level 3 as an infrastructure technician.
      I've also got an NVQ in financial services and a CompTIA A+ that expired
      years ago, which I'm choosing to still be proud of.
    </p>
    <p>
      The day job is service delivery: endpoints and mobile devices, Microsoft
      365, ticketing and ITSM tooling. Keeping people working, mostly
      invisibly.
    </p>
    <p>
      The rest is tinkering. My method, honestly stated: I dabble, I break
      things, I get confused, and I keep going until it's good enough. Lately
      that includes learning to use AI properly as a tool rather than a party
      trick. Away from a terminal I homebrew, play games, and learn things for
      no reason other than wanting to know them.
    </p>

    <h2 id="projects">Projects</h2>
    <p class="muted">
      All self-hosted here on the homelab. Shown, not linked.
    </p>
    {
      renderedProjects.map((p) => (
        <section>
          <h3>{p.data.name}</h3>
          <p class="muted">
            {p.data.status} · {p.data.stack.join(', ')}
          </p>
          <p.Content />
        </section>
      ))
    }

    <h2 id="writing">Writing</h2>
    <p>Occasional notes. No schedule, no niche.</p>
    <ul>
      {
        posts.map((post) => (
          <li>
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time> —
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </li>
        ))
      }
    </ul>
    <p><a href="/blog">All posts</a></p>
  </main>

  <Footer />
</Base>

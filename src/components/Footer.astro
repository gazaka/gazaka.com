---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap">
    <p class="kicker"><em>∗</em> Find me, quietly</p>
    <div class="row">
      <p class="note prose">
        No newsletter. No analytics. No comment section.<br />
        Just a domain that finally has a front door.
      </p>
      <ul class="links">
        <li><a href={site.github} rel="me noopener">GitHub</a></li>
        <li><a href={`mailto:${site.email}`}>Email</a></li>
        <li><a href={site.x} rel="me noopener">X</a></li>
      </ul>
    </div>
    <p class="fine">© {year} {site.name} · Built by hand, served from the homelab.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    margin-top: clamp(6rem, 12vh, 10rem);
    padding-block: 4rem 2.5rem;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
    flex-wrap: wrap;
    margin-top: 2.25rem;
  }

  .note {
    font-size: 0.95rem;
    color: var(--ink-dim);
  }

  .links {
    list-style: none;
    display: flex;
    gap: 2.25rem;
  }

  .links a {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-dim);
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 0.35rem;
  }

  .links a:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .fine {
    margin-top: 3.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
</style>

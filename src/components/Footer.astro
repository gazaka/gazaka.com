---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer>
  <hr />
  <p>
    <a href={site.github} rel="me noopener">GitHub</a> ·
    <a href={`mailto:${site.email}`}>email</a>
  </p>
  <p class="muted">
    © {year} {site.name}. No analytics, no tracking, no cookies. Self-hosted.
  </p>
</footer>

<style>
  footer {
    margin-top: 3rem;
  }

  footer p {
    margin-top: 0.5rem;
  }
</style>

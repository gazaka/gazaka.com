---
interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;
---

<nav>
  {home ? <span>gazaka.com</span> : <a href="/">gazaka.com</a>}
  <a href="/blog">writing</a>
</nav>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
    font-size: 0.9rem;
  }

  nav span {
    color: var(--muted);
  }
</style>

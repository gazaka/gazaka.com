---
interface Props {
  current?: 'home' | 'writing' | 'cv';
}
const { current = 'home' } = Astro.props;
---

<nav class="wrap">
  <a href="/" class="mark" aria-label="gazaka.com home">
    gazaka<span>.com</span>
  </a>
  <div class="links">
    <a href="/#projects" class:list={[{ dim: current !== 'home' }]}>Projects</a>
    <a href="/cv" class:list={[{ dim: current !== 'cv' }]}>CV</a>
    <a href="/blog" class:list={[{ dim: current !== 'writing' }]}>Writing</a>
  </div>
</nav>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-block: 1.75rem;
    position: relative;
    z-index: 10;
  }

  .mark {
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  .mark span {
    color: var(--ink-faint);
  }

  .links {
    display: flex;
    gap: 2rem;
  }

  .links a {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .links a.dim {
    color: var(--ink-dim);
  }
</style>
